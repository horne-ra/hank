# LIVEKIT_URL — wss:// URL from your LiveKit Cloud project
# LIVEKIT_API_KEY — from LiveKit Cloud → Project API keys
# LIVEKIT_API_SECRET — from LiveKit Cloud → Project API keys (shown only once at creation)
# OPENAI_API_KEY — from platform.openai.com, requires Realtime API access (paid tier)

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OPENAI_API_KEY=

# NEXT_PUBLIC_BACKEND_URL — read by the browser (Next.js app in frontend/) to fetch session summaries from the backend API directly; must match your token server host (CORS allows localhost:3000).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
