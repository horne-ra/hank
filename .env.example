# LiveKit Cloud — get from https://cloud.livekit.io → your project → Project API keys
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — needs Realtime API access (paid tier)
OPENAI_API_KEY=

# Frontend → Backend URL (used by SummaryPanel/SessionDetail from the browser)
# Leave as-is for local Docker dev. For production, set to the public backend URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
