# LiveKit Cloud — get from https://cloud.livekit.io → your project → Project API keys
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — needs Realtime API access (paid tier)
OPENAI_API_KEY=

# BACKEND_URL — server-side only; used by Next.js API routes (/api/token,
# /api/summary, /api/sessions) to proxy requests to the backend.
# In Docker, the frontend service sets this to http://token-server:8000.
# For local dev (dev.sh), defaults to http://localhost:8000 if unset.
# BACKEND_URL=http://localhost:8000
