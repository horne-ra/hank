# Copy to .env.local and set values if your token server or summary API is not on localhost:8000.

# Server-side: Next.js API route `/api/token` proxies to this URL.
BACKEND_URL=http://localhost:8000

# Client-side: browser polls `GET /sessions/:id/summary` on this URL for the post-session summary (restart `pnpm dev` after changing).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
